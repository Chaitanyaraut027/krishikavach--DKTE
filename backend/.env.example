# ─────────────────────────────────────────────────────────────────────────────
# KrishiKavach Backend — Environment Variables Template
# ─────────────────────────────────────────────────────────────────────────────
# ⚠️  INSTRUCTIONS FOR TEAM MEMBERS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in YOUR OWN API keys below
#   3. NEVER commit the .env file to GitHub
# ─────────────────────────────────────────────────────────────────────────────

# --- Server ---
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# --- Database ---
# Get your MongoDB connection string from: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/<dbname>

# --- JWT Tokens ---
# Access token: short-lived (~15 min)
JWT_ACCESS_SECRET=replace_with_a_strong_random_secret
JWT_ACCESS_EXPIRATION=15m

# Refresh token: long-lived (~30 days)
JWT_REFRESH_SECRET=replace_with_another_strong_random_secret
JWT_REFRESH_EXPIRATION=30d

# --- Legacy JWT (kept for compatibility) ---
JWT_SECRET=replace_with_supersecret

# --- Cloudinary (for image uploads) ---
# Get keys from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- Government Commodity Price API (data.gov.in) ---
# Steps to get your API key:
#   1. Register at: https://data.gov.in/user/register
#   2. After login, go to: https://data.gov.in/user/me/api-key
#   3. Copy and paste the API key below
GOV_KEY=your_data_gov_in_api_key

# --- Groq AI (for Government Schemes eligibility checker) ---
# Get a FREE API key from: https://console.groq.com
GROK_API_KEY=your_groq_api_key

# --- Google Cloud ---
GOOGLE_CLOUD_PROJECT_ID=your_google_cloud_project_id

# --- OpenWeatherMap API ---
# Get a FREE API key from: https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key

# --- ML Server ---
# Local development — run the Python ML server locally
ML_SERVER_URL=http://127.0.0.1:8000
RENDER=false

# Production (Render cloud) — uncomment when deploying
# ML_SERVER_URL=https://krushi-ml-service.onrender.com
# RENDER=true
